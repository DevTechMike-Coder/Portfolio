---
import { Button } from "../../../components/reuseComp/Button";
import { ArrowLeft } from "../../../components/icons/ArrowLeft";
---

<main class="pt-32 pb-16 px-4 md:px-10 lg:px-20 min-h-screen bg-transparent">
  <a href="/" class="group w-fit block">
    <Button
      variant="secondary"
      size="sm"
      className="flex items-center gap-2 cursor-pointer border border-white/10 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 hover:bg-white/10 hover:border-white/20 transition-all duration-300"
    >
      <ArrowLeft
        className="w-4 h-4 transition-transform group-hover:-translate-x-1"
      />
      <span class="font-medium">Back to Home</span>
    </Button>
  </a>

  <div class="mt-12">
    <h1
      class="text-5xl font-black tracking-tighter bg-linear-to-br from-black to-black/60 bg-clip-text text-transparent"
    >
      Projects
    </h1>
    <p class="text-gray-400 mt-2 max-w-lg">
      A collection of my recent works, experiments, and open-source
      contributions.
    </p>
  </div>
</main>
