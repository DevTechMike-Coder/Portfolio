---
import { TeamUsers } from "../../components/icons/TeamUsers";
import { Button } from "../../components/reuseComp/Button";
import { ChevronRight } from "../../components/icons/ChevronRight";
---

<section class="pt-32 pb-16 px-4 md:px-10 lg:px-20">
  <div class="flex items-center gap-3">
    <TeamUsers fontSize={28} />
    <h2 class="text-3xl md:text-4xl uppercase font-bold tracking-tight">Let's Team Up</h2>
  </div>

  <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
    <div class="flex flex-col justify-center gap-6 p-8 md:p-12 bg-gray-50/50 rounded-3xl border border-gray-100">
      <div class="space-y-2">
        <h1 class="text-4xl md:text-5xl font-bold leading-tight">Got A Project?</h1>
        <p class="text-lg text-gray-500 max-w-md">
          Let's work together and build something truly amazing.
        </p>
      </div>

      <div class="flex items-center">
        <a
          href="mailto:micahkesiena@gmail.com"
          class="inline-flex items-center group"
        >
          <div class="flex bg-black text-white items-center gap-2 rounded-full px-1 py-1 pr-4 transition-all duration-300 hover:bg-gray-800">
            <Button variant="ghost" className="text-white hover:text-white pointer-events-none">
              Send A Message
            </Button>
            <div class="bg-white/20 p-2 rounded-full group-hover:translate-x-1 transition-transform">
              <ChevronRight />
            </div>
          </div>
        </a>
      </div>
    </div>

    <div class="bg-white border-2 border-gray-100 rounded-3xl p-8 md:p-16 flex flex-col items-center justify-center text-center gap-6">
      <div class="flex items-center px-4 py-2 rounded-full border border-gray-200 bg-gray-50">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-600">Featured Projects</h2>
      </div>

      <div class="space-y-2">
        <p class="text-gray-400 italic font-medium">Contributions unavailable for now</p>
        <p class="text-xs text-gray-300 uppercase tracking-widest">Stay Tuned</p>
      </div>
    </div>
  </div>
</section>
