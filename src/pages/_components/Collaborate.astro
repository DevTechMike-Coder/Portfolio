---
import { TeamUsers } from "../../components/icons/TeamUsers";
import { Button } from "../../components/reuseComp/Button";
import { ChevronDown } from "../../components/icons/ChevronDown";
---

<section class="pt-32 pb-16 px-4 md:px-10">
  <div class="flex items-center gap-2">
    <TeamUsers fontSize={24} />
    <h2 class="text-4xl uppercase font-semibold">Let's Team Up</h2>
  </div>

  <div class="flex flex-col gap-3">
    <h1 class="text-2xl font-semibold">Got A Project</h1>
    <p class="text-gray-500">Lets work and build something amazing together</p>

    <div class="flex items-center gap-2">
      <a href="mailto:micahkesiena@gmail.com">
        <Button>Send A Message <ChevronDown /> </Button>
      </a>
    </div>
  </div>
</section>
