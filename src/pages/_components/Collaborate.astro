---
import { TeamUsers } from "../../components/icons/TeamUsers";
import { Button } from "../../components/reuseComp/Button";
import { ChevronRight } from "../../components/icons/ChevronRight";
---

<section class="pt-32 pb-16 px-4 md:px-10">
  <div class="flex items-center gap-2">
    <TeamUsers fontSize={24} />
    <h2 class="text-4xl uppercase font-semibold">Let's Team Up</h2>
  </div>

  <div class="flex flex-col gap-3 px-10 py-3">
    <h1 class="text-4xl font-semibold">Got A Project</h1>
    <p class="text-gray-500">Lets work and build something amazing together</p>

    <div class="flex items-center gap-2">
      <a
        href="mailto:micahkesiena@gmail.com"
        class="flex bg-gray-100 text-black items-center gap-2 rounded-full"
      >
        <Button variant="ghost" className="flex items-center gap-2">Send A Message <ChevronRight /> </Button>
      </a>
    </div>
  </div>
</section>
