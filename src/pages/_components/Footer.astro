---
import { Github } from "../../components/icons/Github";
import { Linkedin } from "../../components/icons/Linkedin";
import { X } from "../../components/icons/X";
import { Email } from "../../components/icons/Email";
import { Instagram } from "../../components/icons/Instagram";

const currentYear = new Date().getFullYear();
---

<footer
  class="w-full border-t border-zinc-200 bg-white/50 backdrop-blur-md mt-20"
>
  <div
    class="max-w-7xl mx-auto px-4 md:px-10 py-8 flex flex-col md:flex-row items-center justify-between gap-6"
  >
    <!-- Left Section: Name, Copyright, Quote -->
    <div
      class="flex flex-col gap-1 items-center md:items-start text-center md:text-left"
    >
      <h2
        class="text-lg md:text-xl font-bold tracking-tight text-zinc-900 font-serif"
      >
        Micah Kesiena
      </h2>
      <p
        class="text-[10px] md:text-xs text-zinc-500 uppercase tracking-widest font-mono mt-2"
      >
        © {currentYear} Micah Kesiena. All rights reserved.
      </p>
      <p class="text-xs text-zinc-400 italic font-serif">
        If it works, don't touch it. If it doesn't, coffee first.
      </p>
    </div>

    <!-- Right Section: Social Icons -->
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/DevTechMike-Coder"
        aria-label="Github"
        class="w-10 h-10 flex items-center justify-center rounded-xl border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 text-zinc-600 hover:text-zinc-900 transition-all shadow-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Github className="w-4 h-4" />
      </a>
      <a
        href="https://x.com/DevTech_Coder23"
        aria-label="X"
        class="w-10 h-10 flex items-center justify-center rounded-xl border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 text-zinc-600 hover:text-zinc-900 transition-all shadow-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        <X className="w-4 h-4" />
      </a>
      <a
        href="https://www.linkedin.com/in/micah-kesiena-a3b424361/"
        aria-label="Linkedin"
        class="w-10 h-10 flex items-center justify-center rounded-xl border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 text-zinc-600 hover:text-zinc-900 transition-all shadow-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Linkedin className="w-4 h-4" />
      </a>
      <a
        href="https://www.instagram.com/micahkingfx2/"
        aria-label="Instagram"
        class="w-10 h-10 flex items-center justify-center rounded-xl border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 text-zinc-600 hover:text-zinc-900 transition-all shadow-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Instagram className="w-4 h-4" />
      </a>
    </div>
  </div>
</footer>
