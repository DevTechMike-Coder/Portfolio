---
import { Briefcase } from "../../components/icons/BriefCase";
import { ChevronDown } from "../../components/icons/ChevronDown";
import { Github } from "../../components/icons/Github";
import { Link } from "../../components/icons/Link";
import { Button } from "../../components/reuseComp/Button";
---

<section class="pt-32 pb-16 px-4 md:px-10">
  <div class="flex items-center gap-2">
    <Briefcase fontSize={30} />
    <h2 class="text-4xl uppercase font-semibold">Project_Log</h2>
  </div>

  <div class="pt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Project Card 1 -->
    <div
      class="group relative overflow-hidden rounded-xl bg-white border border-zinc-200 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-500/10 hover:border-emerald-500/30 shadow-sm"
    >
      <div
        class="absolute inset-0 bg-linear-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>

      <div class="relative z-10 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h2
            class="text-2xl font-bold tracking-tight text-zinc-900 group-hover:text-emerald-600 transition-colors duration-300"
          >
            Next Hub Ecommerce
          </h2>
          <span
            class="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-emerald-500/20 bg-emerald-500/5 text-emerald-700 shadow-[0_0_15px_rgba(16,185,129,0.1)]"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
              ></span>
            </span>
            Completed
          </span>
        </div>

        <div class="h-px w-full bg-linear-to-r from-zinc-200 to-transparent">
        </div>

        <p class="text-zinc-600 text-sm leading-relaxed">
          A high-performance e-commerce platform built with Next.js, featuring a
          seamless shopping experience and robust backend integration.
        </p>

        <div class="pt-2 flex items-center gap-3">
          <a href="https://github.com/DevTechMike-Coder/Ecommerce">
            <Github
              className="text-zinc-600 hover:text-zinc-900 transition-colors"
            />
          </a>
          <div
            class="h-8 w-8 rounded-lg bg-zinc-50 border border-zinc-200 flex items-center justify-center hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all cursor-pointer text-zinc-600 hover:text-emerald-600"
          >
            <a href="https://ecommerce-three-omega-39.vercel.app/">
              <Link />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Project Card 2 -->
    <div
      class="group relative overflow-hidden rounded-xl bg-white border border-zinc-200 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-500/10 hover:border-emerald-500/30 shadow-sm"
    >
      <div
        class="absolute inset-0 bg-linear-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>

      <div class="relative z-10 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h2
            class="text-2xl font-bold tracking-tight text-zinc-900 group-hover:text-emerald-600 transition-colors duration-300"
          >
            Next Hub Ecommerce
          </h2>
          <span
            class="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-emerald-500/20 bg-emerald-500/5 text-emerald-700 shadow-[0_0_15px_rgba(16,185,129,0.1)]"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
              ></span>
            </span>
            Completed
          </span>
        </div>

        <div class="h-px w-full bg-linear-to-r from-zinc-200 to-transparent">
        </div>

        <p class="text-zinc-600 text-sm leading-relaxed">
          A high-performance e-commerce platform built with Next.js, featuring a
          seamless shopping experience and robust backend integration.
        </p>

        <div class="pt-2 flex items-center gap-3">
          <Github
            className="text-zinc-600 hover:text-zinc-900 transition-colors"
          />
          <div
            class="h-8 w-8 rounded-lg bg-zinc-50 border border-zinc-200 flex items-center justify-center hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all cursor-pointer text-zinc-600 hover:text-emerald-600"
          >
            <Link />
          </div>
        </div>
      </div>
    </div>

    <!-- Project Card 3 -->
    <div
      class="group relative overflow-hidden rounded-xl bg-white border border-zinc-200 p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-500/10 hover:border-emerald-500/30 shadow-sm"
    >
      <div
        class="absolute inset-0 bg-linear-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>

      <div class="relative z-10 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h2
            class="text-2xl font-bold tracking-tight text-zinc-900 group-hover:text-emerald-600 transition-colors duration-300"
          >
            Next Hub Ecommerce
          </h2>
          <span
            class="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-emerald-500/20 bg-emerald-500/5 text-emerald-700 shadow-[0_0_15px_rgba(16,185,129,0.1)]"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
              ></span>
            </span>
            Completed
          </span>
        </div>

        <div class="h-px w-full bg-linear-to-r from-zinc-200 to-transparent">
        </div>

        <p class="text-zinc-600 text-sm leading-relaxed">
          A high-performance e-commerce platform built with Next.js, featuring a
          seamless shopping experience and robust backend integration.
        </p>

        <div class="pt-2 flex items-center gap-3">
          <Github
            className="text-zinc-600 hover:text-zinc-900 transition-colors"
          />
          <div
            class="h-8 w-8 rounded-lg bg-zinc-50 border border-zinc-200 flex items-center justify-center hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all cursor-pointer text-zinc-600 hover:text-emerald-600"
          >
            <Link />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pt-16 flex items-center gap-3">
    <div class="h-px w-full bg-linear-to-r from-gray-400 to-transparent"></div>

    <div class="flex flex-col items-center gap-2">
      <p class="text-lg font-medium uppercase">Explore</p>

      <div>
        <Button
          variant="emerald"
          className="flex items-center"
          aria-label="Explore"
        >
          <ChevronDown className="animate-bounce" />
        </Button>
      </div>
    </div>

    <div class="h-px w-full bg-linear-to-r to-gray-400 from-transparent"></div>
  </div>
</section>
