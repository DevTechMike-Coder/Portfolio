---
import { MapPin } from "../../components/icons/MapPin";
---

<section class="relative pt-32 pb-16 px-4 md:px-10 overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="flex flex-col gap-2">
      <div
        class="hero-fade flex items-center gap-2 border border-zinc-200 rounded-full px-4 py-2 w-fit bg-zinc-50/50"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
          ></span>
        </span>
        <span class="text-zinc-600 text-sm font-medium">
          Available for collaborations
        </span>
      </div>
      <h1 class="hero-fade text-4xl font-bold uppercase tracking-wide text-zinc-900">
        Micah Kesiena
      </h1>
      <div class="hero-fade">
        <p class="text-sm text-zinc-500">
          Security Focused Full Stack Developer
        </p>
      </div>
    </div>

    <div class="flex flex-col items-start md:items-end justify-end pt-16">
      <div
        class="hero-fade flex flex-wrap gap-x-4 gap-y-2 border border-zinc-200 w-fit p-2 rounded-full px-4 bg-zinc-50/50"
      >
        <p class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
          <a
            href="https://react.dev"
            aria-label="react"
            target="_blank"
            rel="noopener noreferrer">React</a
          >
        </p>
        <p class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
          <a
            href="https://nextjs.org"
            aria-label="nextjs"
            target="_blank"
            rel="noopener noreferrer">Next.js</a
          >
        </p>
        <p class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
          <a
            href="https://astro.build"
            aria-label="astro"
            target="_blank"
            rel="noopener noreferrer">Astro</a
          >
        </p>
        <p class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
          <a
            href="https://tailwindcss.com"
            aria-label="tailwindcss"
            target="_blank"
            rel="noopener noreferrer">Tailwind CSS</a
          >
        </p>
      </div>
    </div>

    <div class="hero-fade pt-16 flex flex-col items-start md:items-end justify-end">
      <h2 class="text-2xl font-bold uppercase tracking-tight text-zinc-900 md:text-right">
        Full Stack Developer <br /> Penetration Tester
      </h2>
      <div class="flex flex-col items-start md:items-end">
        <p class="text-sm text-zinc-500">
          Innovation for secure websites starts with me
        </p>
        <div class="flex items-center gap-2 text-zinc-600">
          <MapPin className="animate-bounce" />
          <span class="text-sm">Based in Ogun State, Nigeria</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, ease, duration } from "../../lib/gsap";

  const items = gsap.utils.toArray<HTMLElement>(".hero-fade");
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (items.length) {
    if (prefersReduced) {
      gsap.set(items, { opacity: 1, y: 0 });
    } else {
      gsap.fromTo(
        items,
        { opacity: 0, y: 24 },
        {
          opacity: 1,
          y: 0,
          duration: duration.slow,
          ease: ease.smooth,
          stagger: 0.12,
          delay: 0.1,
        },
      );
    }
  }
</script>

