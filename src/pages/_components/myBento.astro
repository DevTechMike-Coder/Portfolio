</section>

<!-- Tooltip -->
<div
  id="gh-tooltip"
  class="fixed z-50 hidden bg-zinc-800 text-white text-xs px-2 py-1 rounded-md shadow-lg pointer-events-none border border-zinc-700 whitespace-nowrap"
>
</div>

<script>
  (function () {
    const clockEl = document.getElementById("live-clock");
    if (!clockEl) return;
    function tick() {
      const now = new Date();
      clockEl!.textContent = now.toLocaleTimeString("en-US", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      });
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

<script>
  type ContributionDay = {
    date: string;
    contributionCount: number;
    color: string;
  };

  type ContributionWeek = {
    contributionDays: ContributionDay[];
  };

  type ContributionData = {
    totalContributions: number;
    weeks: ContributionWeek[];
  };

  const totalEl = document.getElementById("gh-total-contributions");
  const gridEl = document.getElementById("gh-grid");
  const tooltip = document.getElementById("gh-tooltip");

  function setUnavailableState() {
    if (!totalEl || !gridEl) return;

    totalEl.textContent = "--";
    gridEl.className =
      "flex items-center justify-center border border-dashed border-zinc-200 rounded-xl h-[100px] min-w-full";
    gridEl.replaceChildren();

    const message = document.createElement("p");
    message.className = "text-zinc-500 text-xs italic";
    message.textContent = "Contribution data unavailable";
    gridEl.append(message);
  }

  function renderContributionGrid(weeks: ContributionWeek[]) {
    if (!gridEl) return;

    if (weeks.length === 0) {
      setUnavailableState();
      return;
    }

    gridEl.className = "flex gap-1 justify-start min-w-max";
    gridEl.replaceChildren();

    const fragment = document.createDocumentFragment();

    for (const week of weeks.slice(-38)) {
      const weekEl = document.createElement("div");
      weekEl.className = "flex flex-col gap-1";

      for (const day of week.contributionDays) {
        const dayEl = document.createElement("div");
        dayEl.className =
          "w-[15px] h-[15px] rounded-sm cursor-pointer transition-all duration-150 hover:ring-1 hover:ring-zinc-400/30 hover:scale-110 group relative gh-day";
        dayEl.style.backgroundColor = day.color;
        dayEl.dataset.date = day.date;
        dayEl.dataset.count = String(day.contributionCount);
        weekEl.append(dayEl);
      }

      fragment.append(weekEl);
    }

    gridEl.append(fragment);
  }

  async function loadContributions() {
    if (!totalEl || !gridEl) return;

    try {
      const response = await fetch("/api/github-contributions.json", {
        cache: "no-store",
      });

      if (!response.ok) {
        throw new Error(`GitHub contributions request failed: ${response.status}`);
      }

      const data = (await response.json()) as ContributionData;

      totalEl.textContent = data.totalContributions.toLocaleString();
      renderContributionGrid(data.weeks);
    } catch (error) {
      console.error("Unable to load GitHub contributions:", error);
      setUnavailableState();
    }
  }

  function getTooltipText(target: HTMLElement) {
    const count = target.dataset.count;
    const dateStr = target.dataset.date;

    if (!dateStr) {
      return null;
    }

    const date = new Date(`${dateStr}T00:00:00`);
    const formatted = date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });

    return count === "0"
      ? `No contributions on ${formatted}`
      : `${count} contribution${count === "1" ? "" : "s"} on ${formatted}`;
  }

  function positionTooltip(x: number, y: number) {
    if (!tooltip) return;

    const padding = 12;
    const tooltipRect = tooltip.getBoundingClientRect();

    let left = x + padding;
    let top = y - tooltipRect.height - 8;

    if (left + tooltipRect.width > window.innerWidth - padding) {
      left = x - tooltipRect.width - padding;
    }

    if (top < padding) {
      top = y + padding * 2;
    }

    if (top + tooltipRect.height > window.innerHeight - padding) {
      top = window.innerHeight - tooltipRect.height - padding;
    }

    if (left < padding) {
      left = padding;
    }

    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;
  }

  void loadContributions();

  if (gridEl && tooltip) {
    gridEl.addEventListener("mouseover", (e) => {
      const target = (e.target as HTMLElement).closest(".gh-day") as HTMLElement | null;
      if (!target) return;

      const text = getTooltipText(target);
      if (!text) return;

      tooltip.textContent = text;
      tooltip.classList.remove("hidden");
    });

    gridEl.addEventListener("mousemove", (e) => {
      const mouse = e as MouseEvent;
      positionTooltip(mouse.clientX, mouse.clientY);
    });

    gridEl.addEventListener("mouseleave", () => {
      tooltip.classList.add("hidden");
    });

    gridEl.addEventListener(
      "touchstart",
      (e) => {
      const touch = (e as TouchEvent).touches[0];
      const target = document
        .elementFromPoint(touch.clientX, touch.clientY)
        ?.closest(".gh-day") as HTMLElement | null;

      if (target) {
        const text = getTooltipText(target);
        if (!text) return;

        tooltip.textContent = text;
        tooltip.classList.remove("hidden");
        positionTooltip(touch.clientX, touch.clientY);
      } else {
        tooltip.classList.add("hidden");
      }
      },
      { passive: true },
    );

    document.addEventListener("touchstart", (e) => {
      const target = e.target as HTMLElement | null;
      if (!target?.closest(".gh-day")) {
        tooltip.classList.add("hidden");
      }
    });
  }
</script>
