---

<section class="pt-30 pb-16 px-4 md:px-10 max-w-7xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Location Card Component -->
    <div
      class="group relative h-full overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl hover:shadow-emerald-500/5 shadow-sm"
    >
      <!-- Google Maps Background Layer -->
      <GoogleMapBackground client:visible />

      <!-- Foreground Content -->
      <div class="relative z-10 flex flex-col justify-between h-full">
        <div class="flex items-center justify-between">
          <div
            class="bg-zinc-50/80 backdrop-blur-md rounded-full px-4 py-2 w-fit border border-zinc-200"
          >
            <span class="flex items-center gap-2 text-zinc-900 font-medium">
              <MapPin className="text-emerald-600" /> Location</span
            >
          </div>

          <span
            class="border border-zinc-200 bg-zinc-50/80 backdrop-blur-md rounded-full p-1 text-zinc-900"
          >
            <Minus /></span
          >
        </div>

        <div class="mt-auto">
          <h2 class="text-4xl font-black tracking-tighter text-zinc-900">
            Ogun
          </h2>
          <p class="text-zinc-600 font-medium">Nigeria, GMT +1</p>
        </div>
      </div>
    </div>

    <!-- Featured Works Card -->
    <div
      class="md:col-span-2 group relative overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl hover:shadow-purple-500/5 shadow-sm"
    >
      <div class="flex flex-col h-full gap-4">
        <div
          class="border border-zinc-200 bg-zinc-50 px-4 py-1.5 rounded-full w-fit"
        >
          <h2
            class="flex items-center gap-2 text-sm font-medium tracking-wide text-zinc-900"
          >
            <Briefcase className="w-4 h-4 text-purple-600" /> Featured Works
          </h2>
        </div>

        <div
          class="grow flex items-center justify-center border border-dashed border-white/10 rounded-2xl min-h-[120px]"
        >
          <p class="text-gray-500 text-sm italic">
            Coming soon: Exploring innovative security solutions...
          </p>
        </div>
      </div>
    </div>

    <!-- Typing Speed Card -->
    <div
      class="group relative overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl hover:shadow-emerald-500/5 shadow-sm"
    >
      <div class="flex flex-col h-full justify-between gap-6">
        <div
          class="border border-zinc-200 bg-zinc-50 px-4 py-1.5 rounded-full w-fit"
        >
          <h2
            class="flex items-center gap-2 text-sm font-medium tracking-wide text-zinc-900"
          >
            <Keyboard className="w-4 h-4 text-emerald-600" /> Typing Speed
          </h2>
        </div>

        <div>
          <div class="flex items-baseline gap-2">
            <p class="text-4xl font-bold tracking-tighter text-zinc-900">50</p>
            <p class="text-zinc-500 font-medium">WPM</p>
          </div>

          <div class="flex items-center gap-4 mt-6">
            <div
              class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-zinc-50 border border-zinc-200 text-xs font-medium text-zinc-700"
            >
              <Timer className="w-3.5 h-3.5 text-orange-600" />
              <span>15s</span>
            </div>
            <div
              class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-zinc-50 border border-zinc-200 text-xs font-medium text-zinc-700"
            >
              <Accuracy className="w-3.5 h-3.5 text-yellow-600" />
