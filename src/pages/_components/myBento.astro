            </div>
            <div
              class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-zinc-50 border border-zinc-200 text-xs font-medium text-zinc-700"
            >
              <Globe className="w-3.5 h-3.5 text-cyan-600" />
              <span>En</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Social Media Card -->
    <div
      class="group relative overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl shadow-sm"
    >
      <div class="flex flex-col h-full justify-between gap-6">
        <div
          class="border border-zinc-200 bg-zinc-50 px-4 py-1.5 rounded-full w-fit"
        >
          <h2 class="text-sm font-medium tracking-wide text-zinc-900">
            Connect
