import { Marquee } from "../../components/uicomp/Marquee";

type TechStackProps = {
  name: string;
  icon: any;
  description: string;
};

const techStack: TechStackProps[] = [
  {
    name: "Typescript",
    icon: Typescript,
    description: "",
  },
  {
    name: "Javascript",
    icon: Javascript,
    description: "",
  },
  {
    name: "React",
    icon: ReactIcon,
    description: "",
  },
  {
    name: "Nextjs",
    icon: Nextjs,
    description: "",
  },
  {
    name: "Nodejs",
    icon: Nodejs,
    description: "",
  },
  {
    name: "Tailwind",
    icon: Tailwind,
    description: "",
  },
  {
    name: "Astro",
    icon: AstroLogo,
    description: "",
  },
  {
    name: "Express",
    icon: Express,
    description: "",
  },
  {
    name: "Prisma",
    icon: Prisma,
