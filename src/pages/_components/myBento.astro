            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
            ></span>
          </span>
          <Availability className="w-4 h-4" />
          <span
            id="live-clock"
            class="text-xs font-semibold uppercase tracking-wider tabular-nums"
