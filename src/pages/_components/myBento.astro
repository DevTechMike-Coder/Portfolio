      </div>
    </a>

    <!-- Github Contributions -->
    <div
      class="md:col-span-2 group relative overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl shadow-sm"
    >
      <div class="flex flex-col h-full justify-between gap-6">
        <div>
          <div
            class="border border-zinc-200 bg-zinc-50 px-4 py-1.5 rounded-full w-fit"
          >
            <h2
              class="flex items-center gap-2 text-sm font-medium tracking-wide text-zinc-900"
            >
              <Github className="w-4 h-4 text-emerald-600" /> Github Contributions
            </h2>
          </div>

          <div class="mt-4">
            <p class="text-3xl font-bold tracking-tight text-zinc-900">
              {totalContributions.toLocaleString()}
            </p>
            <p
              class="text-zinc-500 text-xs uppercase tracking-wider font-medium"
            >
              Contributions in the last year
            </p>
          </div>
        </div>

        <div>
          {
            weeks.length > 0 ? (
              <div class="flex gap-1 justify-center md:justify-start">
                {weeks.slice(-38).map((week) => (
                  <div class="flex flex-col gap-1">
                    {week.contributionDays.map((day) => (
                      <div
                        class="w-[15px] h-[15px] rounded-sm cursor-pointer transition-all duration-150 hover:ring-1 hover:ring-zinc-400/30 hover:scale-110 group relative gh-day"
                        style={`background-color: ${day.color}`}
                        data-date={day.date}
                        data-count={day.contributionCount}
                      />
                    ))}
                  </div>
                ))}
              </div>
            ) : (
              <div class="flex items-center justify-center border border-dashed border-zinc-200 rounded-xl h-[100px]">
                <p class="text-zinc-500 text-xs italic">
                  Contribution data unavailable
                </p>
              </div>
            )
          }
        </div>
      </div>
    </div>

    <!-- Tech Stack -->
    <div
      class="group relative overflow-hidden border border-zinc-200 bg-white shadow-sm rounded-3xl pt-6 px-6 pb-4 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl flex flex-col"
    >
      <div
        class="border border-zinc-200 bg-zinc-50 rounded-full px-4 py-2 w-fit"
      >
        <h2 class="flex items-center gap-2 m-0 leading-none text-zinc-900">
          <Layers /> Core Tech Stack
        </h2>
      </div>

      <div class="flex items-center grow py-4">
        <Marquee speed={15} className="py-2" client:visible>
          {
            techStack.map((tech) => (
              <div class="group/icon relative p-4 mx-1 rounded-2xl border border-zinc-200 bg-zinc-50 hover:bg-zinc-100 transition-all duration-300 hover:scale-110 flex items-center justify-center min-w-[70px] min-h-[70px]">
                <tech.icon
                  className="w-8 h-8 text-zinc-600 transition-colors"
                  title={tech.name}
                />
              </div>
            ))
          }
        </Marquee>
      </div>

      <div class="mt-auto">
        <p class="text-lg font-medium tracking-tight m-0 text-zinc-900">
          Tech Stack I'm familiar with
        </p>
        <div class="text-sm text-zinc-500">
          <p class="m-0">Innovation starts with me</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Tooltip -->
<div
  id="gh-tooltip"
  class="fixed z-50 hidden bg-zinc-800 text-white text-xs px-2 py-1 rounded-md shadow-lg pointer-events-none border border-zinc-700 whitespace-nowrap"
>
</div>

<script>
  const container =
    document.querySelector(".gh-day")?.parentElement?.parentElement;
  const tooltip = document.getElementById("gh-tooltip");

  if (container && tooltip) {
    container.addEventListener("mouseover", (e) => {
      const target = e.target as HTMLElement;
      if (!target.classList.contains("gh-day")) return;

      const count = target.dataset.count;
      const dateStr = target.dataset.date;
      if (!dateStr) return;

      const date = new Date(dateStr + "T00:00:00");
      const formatted = date.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      });

      tooltip.textContent =
        count === "0"
          ? `No contributions on ${formatted}`
          : `${count} contribution${count === "1" ? "" : "s"} on ${formatted}`;
      tooltip.classList.remove("hidden");
    });

    container.addEventListener("mousemove", (e) => {
      const mouse = e as MouseEvent;
      tooltip.style.left = `${mouse.clientX + 12}px`;
      tooltip.style.top = `${mouse.clientY - 28}px`;
    });

    container.addEventListener("mouseout", (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains("gh-day")) {
        tooltip.classList.add("hidden");
      }
    });
  }
</script>
