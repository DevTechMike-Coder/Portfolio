<div id="gh-tooltip" class="fixed z-50 hidden bg-zinc-800 text-white text-xs px-2 py-1 rounded-md shadow-lg pointer-events-none border border-zinc-700 whitespace-nowrap"></div>

<style>
  /* Touch-device fallback: hover never fires on touch, so toggle this class via JS */
  .tech-chip.force-reveal .tech-chip-label {
    opacity: 1 !important;
  }
</style>

<script>
  import { revealOnScroll } from "../../lib/gsap";
  const grid = document.getElementById("bento-grid");
  if (grid) {
    revealOnScroll(Array.from(grid.children) as HTMLElement[], {
      trigger: grid,
      start: "top 80%",
      stagger: 0.1,
      y: 24,
      hideOnExit: true,
    });
  }
</script>

<script>
  (function () {
    const clockEl = document.getElementById("live-clock");
    if (!clockEl) return;
    function tick() {
      const now = new Date();
      clockEl!.textContent = now.toLocaleTimeString("en-US", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      });
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

<script>
  (function () {
    const marqueeWrapper = document.getElementById("tech-marquee");
    if (!marqueeWrapper) return;

    const marqueeTrack = marqueeWrapper.querySelector('[class*="marquee"], [class*="track"]') as HTMLElement | null;

    function setMarqueePaused(paused: boolean) {
      if (marqueeTrack) {
        marqueeTrack.style.animationPlayState = paused ? "paused" : "running";
      } else {
        marqueeWrapper.querySelectorAll('*').forEach((el) => {
          const style = window.getComputedStyle(el);
          if (style.animationName && style.animationName !== 'none') {
            (el as HTMLElement).style.animationPlayState = paused ? "paused" : "running";
          }
        });
      }
    }

    // Detect touch/coarse-pointer devices where :hover never fires
    const isTouchDevice = window.matchMedia("(hover: none), (pointer: coarse)").matches;

    marqueeWrapper.addEventListener("mouseover", (event) => {
      if (isTouchDevice) return;
      const target = event.target as HTMLElement;
      if (target.closest(".tech-chip")) {
        setMarqueePaused(true);
      }
    });

    marqueeWrapper.addEventListener("mouseout", (event) => {
      if (isTouchDevice) return;
      const target = event.target as HTMLElement;
      if (target.closest(".tech-chip")) {
        setMarqueePaused(false);
      }
    });

    // Touch/click fallback: tap a chip to reveal its label, tap elsewhere to clear
    function toggleReveal(chip: HTMLElement) {
      const wasActive = chip.classList.contains("force-reveal");
      marqueeWrapper!.querySelectorAll(".tech-chip.force-reveal").forEach((el) => {
        el.classList.remove("force-reveal");
      });
      if (!wasActive) {
        chip.classList.add("force-reveal");
        setMarqueePaused(true);
        // Auto-clear after a beat so the marquee doesn't stay paused forever on touch
        window.setTimeout(() => {
          chip.classList.remove("force-reveal");
          setMarqueePaused(false);
        }, 1800);
      } else {
        setMarqueePaused(false);
      }
    }

    marqueeWrapper.addEventListener("click", (event) => {
      const chip = (event.target as HTMLElement).closest(".tech-chip") as HTMLElement | null;
      if (!chip) return;
      toggleReveal(chip);
    });

    marqueeWrapper.addEventListener("keydown", (event) => {
      const ke = event as KeyboardEvent;
      if (ke.key !== "Enter" && ke.key !== " ") return;
      const chip = (ke.target as HTMLElement).closest(".tech-chip") as HTMLElement | null;
      if (!chip) return;
      ke.preventDefault();
      toggleReveal(chip);
    });
  })();
</script>

<script>
  type ContributionDay = { date: string; contributionCount: number; color: string; };
  type ContributionWeek = { contributionDays: ContributionDay[]; };
  type ContributionData = { totalContributions: number; weeks: ContributionWeek[]; };

  const totalEl = document.getElementById("gh-total-contributions");
  const gridEl = document.getElementById("gh-grid");
  const tooltip = document.getElementById("gh-tooltip");

  function setUnavailableState() {
    if (!totalEl || !gridEl) return;
    totalEl.textContent = "--";
    gridEl.className = "flex items-center justify-center border border-dashed border-zinc-200 rounded-xl h-[100px] min-w-full";
    gridEl.replaceChildren();
    const message = document.createElement("p");
    message.className = "text-zinc-500 text-xs italic";
    message.textContent = "Contribution data unavailable";
    gridEl.append(message);
  }

  function renderContributionGrid(weeks: ContributionWeek[]) {
    if (!gridEl) return;
    if (weeks.length === 0) { setUnavailableState(); return; }

    gridEl.className = "flex gap-1 justify-start min-w-max";
    gridEl.replaceChildren();
    const fragment = document.createDocumentFragment();

    for (const week of weeks.slice(-38)) {
      const weekEl = document.createElement("div");
      weekEl.className = "flex flex-col gap-1";
      for (const day of week.contributionDays) {
        const dayEl = document.createElement("div");
        dayEl.className = "w-[15px] h-[15px] rounded-sm cursor-pointer transition-all duration-150 hover:ring-1 hover:ring-zinc-400/30 hover:scale-110 group relative gh-day";
        dayEl.style.backgroundColor = day.color;
        dayEl.dataset.date = day.date;
        dayEl.dataset.count = String(day.contributionCount);
        weekEl.append(dayEl);
      }
      fragment.append(weekEl);
    }
    gridEl.append(fragment);
  }

  async function loadContributions() {
    if (!totalEl || !gridEl) return;
    try {
      const response = await fetch("/api/github-contributions.json", { cache: "no-store" });
      if (!response.ok) throw new Error(`GitHub request failed: ${response.status}`);
      const data = (await response.json()) as ContributionData;
      totalEl.textContent = data.totalContributions.toLocaleString();
      renderContributionGrid(data.weeks);
    } catch (error) {
      console.error(error);
      setUnavailableState();
    }
  }

  function getTooltipText(target: HTMLElement) {
    const count = target.dataset.count;
    const dateStr = target.dataset.date;
    if (!dateStr) return null;
    const date = new Date(`${dateStr}T00:00:00`);
    const formatted = date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    return count === "0" ? `No contributions on ${formatted}` : `${count} contribution${count === "1" ? "" : "s"} on ${formatted}`;
  }

  function positionTooltip(x: number, y: number) {
    if (!tooltip) return;
    const padding = 12;
    const tooltipRect = tooltip.getBoundingClientRect();
    let left = x + padding;
    let top = y - tooltipRect.height - 8;
    if (left + tooltipRect.width > window.innerWidth - padding) left = x - tooltipRect.width - padding;
    if (top < padding) top = y + padding * 2;
    if (top + tooltipRect.height > window.innerHeight - padding) top = window.innerHeight - tooltipRect.height - padding;
    if (left < padding) left = padding;
    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;
  }

  void loadContributions();

  if (gridEl && tooltip) {
    gridEl.addEventListener("mouseover", (e) => {
      const target = (e.target as HTMLElement).closest(".gh-day") as HTMLElement | null;
      if (!target) return;
      const text = getTooltipText(target);
      if (!text) return;
      tooltip.textContent = text;
      tooltip.classList.remove("hidden");
    });
    gridEl.addEventListener("mousemove", (e) => { positionTooltip((e as MouseEvent).clientX, (e as MouseEvent).clientY); });
    gridEl.addEventListener("mouseleave", () => { tooltip.classList.add("hidden"); });
  }
</script>