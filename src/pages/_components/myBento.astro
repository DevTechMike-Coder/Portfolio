            <p id="gh-total-contributions" class="text-3xl font-bold tracking-tight text-zinc-900">--</p>
            <p class="text-zinc-500 text-xs uppercase tracking-wider font-medium">Live GitHub contributions in the last year</p>
          </div>
        </div>
        <div class="overflow-x-auto pb-1">
          <div id="gh-grid" class="flex items-center justify-center border border-dashed border-zinc-200 rounded-xl h-[100px] min-w-full" aria-live="polite">
            <p class="text-zinc-500 text-xs italic">Loading contribution data</p>
          </div>
        </div>
      </div>
    </div>

    {/* Core Tech Stack Section With Layout Clip Fix */}
    <div class="group relative overflow-hidden border border-zinc-200 bg-white shadow-sm rounded-3xl pt-6 px-6 pb-4 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl flex flex-col">
      <div class="border border-zinc-200 bg-zinc-50 rounded-full px-4 py-2 w-fit">
        <h2 class="flex items-center gap-2 m-0 leading-none text-zinc-900"><Layers /> Core Tech Stack</h2>
      </div>

      {/* Added clear vertical padding spaces for the text elements inside Marquee boundaries */}
      <div id="tech-marquee" class="flex items-center grow pt-6 pb-2">
        <Marquee speed={15} className="py-6" client:visible>
          {
            techStack.map((tech) => (
              <div
                class="tech-chip group/item flex flex-col items-center mx-2.5 cursor-pointer select-none h-24 justify-start"
