        >
          <h2 class="text-sm font-medium tracking-wide text-zinc-900">
            Connect
          </h2>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://x.com/DevTech_Coder23"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X"
            class="p-3 rounded-2xl border border-zinc-200 bg-zinc-50 hover:bg-zinc-100 text-zinc-900 transition-all duration-300 hover:scale-110"
          >
            <X className="w-6 h-6" />
          </a>
          <a
            href="https://www.instagram.com/micahkingfx2/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="p-3 rounded-2xl border border-zinc-200 bg-zinc-50 hover:bg-zinc-100 text-zinc-900 transition-all duration-300 hover:scale-110"
          >
            <Instagram className="w-6 h-6" />
          </a>
          <a
            href="https://www.linkedin.com/in/micah-kesiena-a3b424361/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="p-3 rounded-2xl border border-zinc-200 bg-zinc-50 hover:bg-zinc-100 text-zinc-900 transition-all duration-300 hover:scale-110"
