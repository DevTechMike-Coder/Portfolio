  { name: "Javascript", icon: Javascript, description: "" },
  { name: "React", icon: ReactIcon, description: "" },
  { name: "Nextjs", icon: Nextjs, description: "" },
  { name: "Nodejs", icon: Nodejs, description: "" },
  { name: "Tailwind", icon: Tailwind, description: "" },
  { name: "Astro", icon: AstroLogo, description: "" },
  { name: "Express", icon: Express, description: "" },
  { name: "Prisma", icon: Prisma, description: "" },
  { name: "Mongodb", icon: Mongodb, description: "" },
  { name: "Postgresql", icon: Postgresql, description: "" },
  { name: "RedisCloud", icon: RedisCloud, description: "" },
