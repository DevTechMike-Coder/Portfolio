          >
            <Instagram className="w-6 h-6" />
          </a>
          <a
            href="https://www.linkedin.com/in/%C3%B0%C9%9Bv-t%C9%9Bc%C4%A5-8a7507344/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="p-3 rounded-2xl border border-zinc-200 bg-zinc-50 hover:bg-zinc-100 text-zinc-900 transition-all duration-300 hover:scale-110"
          >
            <Linkedin className="w-6 h-6" />
          </a>
        </div>
      </div>
    </div>

    <!-- Learn More Card -->
    <a
      href="/projects"
      class="group relative overflow-hidden border border-zinc-200 bg-white rounded-3xl p-6 transition-all duration-300 hover:border-zinc-300 hover:shadow-xl shadow-sm flex flex-col justify-between gap-4"
    >
      <div
        class="border border-zinc-200 bg-zinc-50 px-4 py-1.5 rounded-full w-fit"
      >
        <h2
          class="flex items-center gap-2 text-sm font-medium tracking-wide text-zinc-900"
        >
          Projects
        </h2>
      </div>
      <div class="flex items-center justify-between">
        <p class="text-lg font-medium tracking-tight text-zinc-900">
          Explore my latest projects & tools
        </p>
        <div
          class="w-10 h-10 rounded-full border border-zinc-200 flex items-center justify-center group-hover:bg-zinc-50 transition-all duration-300 group-hover:translate-x-1 text-zinc-900"
        >
          <ChevronRight className="w-5 h-5" />
