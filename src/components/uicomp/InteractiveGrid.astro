---
/**
 * InteractiveGrid - A premium background component
 * Features a CSS grid pattern and a mouse-tracked spotlight glow.
 */
---

<div
  class="interactive-grid-container fixed inset-0 -z-10 overflow-hidden pointer-events-none"
  id="grid-container"
>
  <div class="grid-pattern absolute inset-0"></div>
  <div
    class="spotlight absolute inset-0 transition-opacity duration-500 opacity-0"
    id="spotlight"
  >
  </div>
</div>

<style>
  .interactive-grid-container {
    mask-image: radial-gradient(circle at center, black, transparent 80%);
  }

  .grid-pattern {
    background-image:
      linear-gradient(to right, currentColor 1px, transparent 1px),
      linear-gradient(to bottom, currentColor 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.1;
  }

  .spotlight {
    background: radial-gradient(
      circle 350px at var(--x, 50%) var(--y, 50%),
      rgba(16, 185, 129, 0.6),
      transparent 80%
    );
  }
</style>

<script>
  const spotlight = document.getElementById("spotlight");

  if (spotlight) {
    window.addEventListener("mousemove", (e) => {
      spotlight.style.setProperty("--x", `${e.clientX}px`);
      spotlight.style.setProperty("--y", `${e.clientY}px`);
      spotlight.style.opacity = "1";
    });

    window.addEventListener("mouseout", (e) => {
      if (!e.relatedTarget) {
        spotlight.style.opacity = "0";
      }
    });
  }
</script>
